# Point the client at the Python audio-engine to switch from mock grading to real CREPE/DTW grading.
# Start the engine: cd audio-engine && source .venv/bin/activate && uvicorn main:app --port 8001
VITE_AUDIO_ENGINE_URL=http://127.0.0.1:8001
# Node backend — enables real Claude mentor chat + persistent progress.
# Start: cd server && npm run dev
VITE_SERVER_URL=http://127.0.0.1:8000
